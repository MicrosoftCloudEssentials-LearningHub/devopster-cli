{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "DevOpster",
  "version": "0.1.0",
  "identifier": "io.cloud2br.devopster",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "DevOpster",
        "width": 1180,
        "height": 800,
        "minWidth": 960,
        "minHeight": 640,
        "resizable": true,
        "center": true,
        "decorations": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com; font-src 'self' https://fonts.gstatic.com; script-src 'self' 'unsafe-inline'; connect-src 'self' ipc: https://ipc.localhost"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "category": "DeveloperTool",
    "shortDescription": "DevOpster — DevOps control plane",
    "longDescription": "Cross-platform desktop app for repository governance across GitHub, Azure DevOps, and GitLab.",
    "copyright": "Copyright (c) 2026 Cloud2BR",
    "publisher": "Cloud2BR",
    "homepage": "https://cloud2br.github.io/devopster-cli/",
    "externalBin": ["binaries/devopster"],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "frameworks": []
    },
    "windows": {
      "wix": {
        "language": "en-US"
      },
      "nsis": {
        "installMode": "perMachine",
        "displayLanguageSelector": false
      }
    },
    "linux": {
      "deb": {
        "section": "devel",
        "priority": "optional"
      },
      "appimage": {
        "bundleMediaFramework": false
      }
    }
  },
  "plugins": {
    "shell": {
      "open": true,
      "scope": [
        {
          "name": "devopster-sidecar",
          "sidecar": true,
          "args": true
        }
      ]
    }
  }
}
